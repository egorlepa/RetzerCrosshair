{
    "Lua.runtime.version": "Lua 5.1",
    "Lua.runtime.builtin": {
        "basic": "disable",
        "debug": "disable",
        "io": "disable",
        "math": "disable",
        "os": "disable",
        "package": "disable",
        "string": "disable",
        "table": "disable",
        "utf8": "disable"
    },
    "Lua.workspace.library": [
        "~/.vscode-server/extensions/ketho.wow-api-0.22.3/Annotations/Core"
    ],
    "Lua.diagnostics.globals": [
        "SlashCmdList",
        "STANDARD_TEXT_FONT",
        "UISpecialFrames",
        "ColorPickerFrame",
        "RAID_CLASS_COLORS"
    ],
    "Lua.diagnostics.disable": [
        "assign-type-mismatch"
    ],
    "Lua.type.weakUnionCheck": true
}
